
config smartdns
	option server_name 'smartdns'
	option port '5353'
	option auto_set_dnsmasq '0'
	option tcp_server '0'
	option tls_server '0'
	option doh_server '0'
	option ipv6_server '0'
	option bind_device '0'
	option dualstack_ip_selection '0'
	option serve_expired '0'
	option cache_persist '0'
	option resolve_local_hostnames '0'
	option force_https_soa '0'
	option rr_ttl_min '0'
	option seconddns_port '6553'
	option seconddns_tcp_server '1'
	option log_output_mode 'file'
	option enabled '1'
	option ui '0'
	option old_port '5353'
	option old_enabled '1'
	option old_auto_set_dnsmasq '0'

config domain-rule

config client-rule
	option enabled '0'
	option dualstack_ip_selection '1'
	option force_https_soa '1'

config ip-rule
	option enabled '1'

