
config interface 'loopback'
	option device 'lo'
	option proto 'static'
	list ipaddr '127.0.0.1/8'

config globals 'globals'
	option dhcp_default_duid '0004fcae66489f3e45f68d1f5b54336b0cc6'
	option packet_steering '2'
	option steering_flows '128'

config device
	option name 'br-lan'
	option type 'bridge'
	list ports 'eth0'

config interface 'lan'
	option device 'br-lan'
	option proto 'static'
	option ip6assign '64'
	option ipv6 '1'
	list dns '127.0.0.1'
	option multipath 'off'
	list ipaddr '192.168.1.1/24'

config interface 'Modem_v4'
	option proto 'dhcp'
	option device 'eth1'
	option peerdns '0'
	option multipath 'off'

config interface 'Modem_v6'
	option proto 'dhcpv6'
	option reqaddress 'try'
	option reqprefix 'auto'
	option device '@Modem_v4'
	option extendprefix '1'
	option peerdns '0'
	option norelease '1'
	option multipath 'off'

config device
	option name 'eth1'
	option mtu '1492'
	option mtu6 '1492'

